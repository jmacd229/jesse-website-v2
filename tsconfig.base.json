{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "esnext",
    "lib": ["es2023", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@jmacd229/design-system": ["./libs/design-system/src/index.ts"],
      "@test-utils/*": ["./test-utils/*"],
      "test-utils": ["./test-utils/index.tsx"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
